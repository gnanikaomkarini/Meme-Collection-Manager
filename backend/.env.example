# Server Port
PORT=3000

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/memesDB
DATABASE_NAME=memesDB

# Google OAuth 2.0 Credentials
# Get these from: https://console.cloud.google.com/
# 1. Create a new project
# 2. Enable Google+ API
# 3. Create OAuth 2.0 credentials (Web Application)
# 4. Add authorized redirect URIs: http://localhost:3000/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Session Cookie Encryption Key
# Generate a random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_KEY=your-super-secret-cookie-encryption-key-here

# Frontend URL (used for redirects after OAuth)
FRONTEND_URL=http://localhost:4200

# Backend URL (used in OAuth callback configuration)
BACKEND_URL=http://localhost:3000